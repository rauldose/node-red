@using Syncfusion.Blazor.Layouts
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Buttons

@*
    RedUiSidebarInfo - Blazor implementation using pure Syncfusion components
    Uses SfTreeView for tree list and SfSplitter for resizable panels
*@

<SfSplitter Height="100%" Width="100%" Orientation="Orientation.Vertical">
    <SplitterPanes>
        @* Outliner panel (tree view of flows) *@
        <SplitterPane Size="40%" Min="100px" Collapsible="true">
            <ContentTemplate>
                <SfTreeView TValue="TreeItem" @ref="_treeView" CssClass="sidebar-info-tree">
                    <TreeViewEvents TValue="TreeItem" NodeClicked="OnNodeClicked" NodeExpanded="OnNodeExpanded" NodeCollapsed="OnNodeCollapsed"></TreeViewEvents>
                    <TreeViewFieldsSettings TValue="TreeItem" 
                        DataSource="@_treeData"
                        Id="Id" 
                        Text="Text" 
                        ParentID="ParentId" 
                        HasChildren="HasChildren"
                        Expanded="IsExpanded"
                        IconCss="IconCss">
                    </TreeViewFieldsSettings>
                </SfTreeView>
            </ContentTemplate>
        </SplitterPane>

        @* Properties panel *@
        <SplitterPane Min="100px">
            <ContentTemplate>
                <div style="height: 100%; display: flex; flex-direction: column; overflow: hidden;">
                    @* Header with node info *@
                    <div style="padding: 8px 12px; border-bottom: 1px solid #e0e0e0; background: #f5f5f5; display: flex; align-items: center; gap: 8px;">
                        @if (SelectedNode != null)
                        {
                            <span style="width: 24px; height: 18px; background-color: @NodeColor; border: 1px solid #bbb; border-radius: 3px;"></span>
                            <span style="flex: 1; font-weight: 500;">@NodeType</span>
                            <SfButton IconCss="fa fa-book" CssClass="e-small e-flat" Title="Show node help" OnClick="@(() => OnHelpClick.InvokeAsync())"></SfButton>
                            <SfButton IconCss="fa fa-link" CssClass="e-small e-flat" Title="Copy node path" OnClick="@(() => OnCopyLinkClick.InvokeAsync())"></SfButton>
                            <SfButton IconCss="fa fa-search" CssClass="e-small e-flat" Title="Reveal in workspace" OnClick="@(() => OnRevealClick.InvokeAsync())"></SfButton>
                        }
                        else
                        {
                            <span style="color: #888;">No selection</span>
                        }
                    </div>

                    @* Properties table *@
                    <div style="flex: 1; overflow-y: auto; padding: 12px;">
                        @if (SelectedNode != null)
                        {
                            <table style="width: 100%; border-collapse: collapse;">
                                <tbody>
                                    <tr>
                                        <td style="padding: 6px 10px; background: #fafafa; width: 80px; color: #666; border-bottom: 1px solid #eee;">node</td>
                                        <td style="padding: 6px 10px; border-bottom: 1px solid #eee;">@NodeId</td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 6px 10px; background: #fafafa; color: #666; border-bottom: 1px solid #eee;">type</td>
                                        <td style="padding: 6px 10px; border-bottom: 1px solid #eee;">@NodeType</td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 6px 10px; background: #fafafa; color: #666; border-bottom: 1px solid #eee;">name</td>
                                        <td style="padding: 6px 10px; border-bottom: 1px solid #eee;">@(NodeName ?? "(none)")</td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(StatusText))
                                    {
                                        <tr>
                                            <td style="padding: 6px 10px; background: #fafafa; color: #666; border-bottom: 1px solid #eee;">status</td>
                                            <td style="padding: 6px 10px; border-bottom: 1px solid #eee;">
                                                <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background-color: @StatusColor; margin-right: 6px;"></span>
                                                @StatusText
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                            @if (!string.IsNullOrEmpty(NodeDescription))
                            {
                                <div style="margin-top: 12px; padding: 10px; background: #fafafa; border-radius: 4px;">
                                    <p style="margin: 0;">@NodeDescription</p>
                                </div>
                            }
                        }
                        else
                        {
                            <div style="color: #888; text-align: center; padding: 24px;">
                                Select a node or flow to view info
                            </div>
                        }
                    </div>

                    @* Tips at bottom *@
                    @if (_showTips)
                    {
                        <div style="padding: 8px 12px; background: #fffde7; border-top: 1px solid #e0e0e0; display: flex; align-items: center;">
                            <i class="fa fa-lightbulb-o" style="margin-right: 8px; color: #f9a825;"></i>
                            <span style="flex: 1; font-size: 13px;">@_displayTip</span>
                            <SfButton IconCss="fa fa-refresh" CssClass="e-small e-flat" Title="Next tip" OnClick="NextTip"></SfButton>
                            <SfButton IconCss="fa fa-times" CssClass="e-small e-flat" Title="Hide tips" OnClick="HideTips"></SfButton>
                        </div>
                    }
                </div>
            </ContentTemplate>
        </SplitterPane>
    </SplitterPanes>
</SfSplitter>

@code {
    [Parameter] public object? SelectedNode { get; set; }
    [Parameter] public string NodeId { get; set; } = "";
    [Parameter] public string NodeType { get; set; } = "";
    [Parameter] public string? NodeName { get; set; }
    [Parameter] public string NodeColor { get; set; } = "#ddd";
    [Parameter] public string? NodeDescription { get; set; }
    [Parameter] public string? StatusText { get; set; }
    [Parameter] public string StatusColor { get; set; } = "transparent";
    [Parameter] public string? SelectedNodeId { get; set; }
    [Parameter] public string? SelectedFlowId { get; set; }
    [Parameter] public string CurrentTip { get; set; } = "Double-click a node to edit its properties";
    [Parameter] public List<FlowInfo> Flows { get; set; } = new();
    [Parameter] public List<NodeInfo> GlobalConfigNodes { get; set; } = new();
    [Parameter] public EventCallback<string> OnNodeSelected { get; set; }
    [Parameter] public EventCallback<string> OnFlowSelected { get; set; }
    [Parameter] public EventCallback OnRevealClick { get; set; }
    [Parameter] public EventCallback OnCopyLinkClick { get; set; }
    [Parameter] public EventCallback OnHelpClick { get; set; }
    [Parameter] public Func<string, List<NodeInfo>>? GetFlowNodesFunc { get; set; }

    private SfTreeView<TreeItem>? _treeView;
    private List<TreeItem> _treeData = new();

    // Tips
    private string[] _tips = new[]
    {
        "Double-click a node to edit its properties",
        "Use Ctrl+Z to undo changes",
        "Press Delete to remove selected nodes",
        "Ctrl+click to select multiple nodes"
    };
    private int _currentTipIndex = 0;
    private string _displayTip = "";
    private bool _showTips = true;

    protected override void OnInitialized()
    {
        _displayTip = CurrentTip;
        RefreshTreeData();
    }

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(_displayTip))
        {
            _displayTip = CurrentTip;
        }
        RefreshTreeData();
    }

    private void RefreshTreeData()
    {
        _treeData = BuildTreeData();
    }

    private List<TreeItem> BuildTreeData()
    {
        var items = new List<TreeItem>();

        // Flows section
        items.Add(new TreeItem
        {
            Id = "flows",
            Text = "Flows",
            ParentId = null,
            HasChildren = Flows.Any(),
            IsExpanded = true,
            IconCss = "fa fa-sitemap"
        });

        foreach (var flow in Flows)
        {
            var flowNodes = GetFlowNodesFunc?.Invoke(flow.Id) ?? new List<NodeInfo>();
            items.Add(new TreeItem
            {
                Id = flow.Id,
                Text = flow.Label,
                ParentId = "flows",
                HasChildren = flowNodes.Any(),
                IsExpanded = false,
                IconCss = "fa fa-sitemap",
                IsFlow = true
            });

            foreach (var node in flowNodes)
            {
                items.Add(new TreeItem
                {
                    Id = node.Id,
                    Text = node.Name ?? node.Type,
                    ParentId = flow.Id,
                    HasChildren = false,
                    Color = node.Color,
                    IsNode = true
                });
            }
        }

        // Subflows section
        items.Add(new TreeItem
        {
            Id = "subflows",
            Text = "Subflows",
            ParentId = null,
            HasChildren = false,
            IsExpanded = false,
            IconCss = "fa fa-share-alt"
        });

        // Global Configuration section
        items.Add(new TreeItem
        {
            Id = "global-config",
            Text = "Global Configuration",
            ParentId = null,
            HasChildren = GlobalConfigNodes.Any(),
            IsExpanded = false,
            IconCss = "fa fa-cog"
        });

        foreach (var node in GlobalConfigNodes)
        {
            items.Add(new TreeItem
            {
                Id = node.Id,
                Text = node.Name ?? node.Type,
                ParentId = "global-config",
                HasChildren = false,
                Color = node.Color,
                IsNode = true
            });
        }

        return items;
    }

    private async Task OnNodeClicked(NodeClickEventArgs args)
    {
        var nodeData = args.NodeData;
        if (nodeData.IsFlow)
        {
            await OnFlowSelected.InvokeAsync(nodeData.Id);
        }
        else if (nodeData.IsNode)
        {
            await OnNodeSelected.InvokeAsync(nodeData.Id);
        }
    }

    private void OnNodeExpanded(NodeExpandEventArgs args) { }
    private void OnNodeCollapsed(NodeExpandEventArgs args) { }

    private void NextTip()
    {
        _currentTipIndex = (_currentTipIndex + 1) % _tips.Length;
        _displayTip = _tips[_currentTipIndex];
    }

    private void HideTips()
    {
        _showTips = false;
    }

    public class TreeItem
    {
        public string Id { get; set; } = "";
        public string Text { get; set; } = "";
        public string? ParentId { get; set; }
        public bool HasChildren { get; set; } = false;
        public bool IsExpanded { get; set; } = false;
        public string? IconCss { get; set; }
        public string? Color { get; set; }
        public bool IsFlow { get; set; } = false;
        public bool IsNode { get; set; } = false;
    }

    public class FlowInfo
    {
        public string Id { get; set; } = "";
        public string Label { get; set; } = "";
        public bool Disabled { get; set; } = false;
    }

    public class NodeInfo
    {
        public string Id { get; set; } = "";
        public string Type { get; set; } = "";
        public string? Name { get; set; }
        public string Color { get; set; } = "#ddd";
    }
}
