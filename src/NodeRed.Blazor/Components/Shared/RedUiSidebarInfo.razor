@*
    RedUiSidebarInfo - Blazor implementation of Node-RED's tab-info.js
    Uses Syncfusion SfSplitter and SfTreeView for proper functionality
*@

<div class="red-ui-sidebar-info" style="height: 100%; display: flex; flex-direction: column;">
    @* Split panel using Syncfusion Splitter *@
    <SfSplitter Orientation="Syncfusion.Blazor.Layouts.Orientation.Vertical" CssClass="red-ui-info-splitter" Height="100%">
        <SplitterPanes>
            @* Outliner panel (tree view of flows) *@
            <SplitterPane Size="60%" Min="100px" Collapsible="true">
                <ContentTemplate>
                    <div class="red-ui-info-outliner" style="height: 100%; overflow: auto;">
                        <SfTreeView TValue="TreeItem" CssClass="red-ui-treeview" @ref="_treeView">
                            <TreeViewFieldsSettings TValue="TreeItem"
                                                    DataSource="@GetTreeData()"
                                                    Id="Id"
                                                    Text="Text"
                                                    ParentID="ParentId"
                                                    HasChildren="HasChildren"
                                                    Expanded="Expanded">
                            </TreeViewFieldsSettings>
                            <TreeViewEvents TValue="TreeItem" NodeClicked="OnNodeClicked" NodeExpanding="OnNodeExpanding"></TreeViewEvents>
                            <TreeViewTemplates TValue="TreeItem">
                                <NodeTemplate>
                                    <div class="red-ui-tree-node @(GetNodeSelectionClass(context))">
                                        @if (context.IsNode && !string.IsNullOrEmpty(context.Color))
                                        {
                                            <span class="red-ui-node-icon-container" style="background-color: @context.Color;">
                                                @if (!string.IsNullOrEmpty(context.IconCss))
                                                {
                                                    <i class="@context.IconCss red-ui-node-icon"></i>
                                                }
                                            </span>
                                        }
                                        else if (!string.IsNullOrEmpty(context.IconCss))
                                        {
                                            <i class="@context.IconCss red-ui-tree-icon"></i>
                                        }
                                        <span class="red-ui-tree-node-label">@context.Text</span>
                                    </div>
                                </NodeTemplate>
                            </TreeViewTemplates>
                        </SfTreeView>
                    </div>
                </ContentTemplate>
            </SplitterPane>

            @* Properties panel *@
            <SplitterPane Size="40%" Min="100px">
                <ContentTemplate>
                    <div class="red-ui-info-properties" style="height: 100%; overflow: hidden; display: flex; flex-direction: column;">
                        @* Header with node type icon and name *@
                        <div class="red-ui-palette-header red-ui-info-header">
                            @if (SelectedNode != null)
                            {
                                <span class="red-ui-info-header-icon" style="background-color: @NodeColor;"></span>
                                <span class="red-ui-info-header-label">@NodeType</span>

                                @* Action buttons *@
                                <button type="button" class="red-ui-button red-ui-button-small red-ui-info-header-button"
                                        title="Show node help" @onclick="OnHelpClick">
                                    <i class="fa fa-book"></i>
                                </button>
                                <button type="button" class="red-ui-button red-ui-button-small red-ui-info-header-button"
                                        title="Copy node path" @onclick="OnCopyLinkClick">
                                    <i class="fa fa-link"></i>
                                </button>
                                <button type="button" class="red-ui-button red-ui-button-small red-ui-info-header-button"
                                        title="Reveal in workspace" @onclick="OnRevealClick">
                                    <i class="fa fa-search"></i>
                                </button>
                            }
                            else
                            {
                                <span class="red-ui-info-header-none">No selection</span>
                            }
                        </div>

                        @* Properties content *@
                        <div class="red-ui-info-properties-content" style="flex: 1; overflow-y: auto; padding: 10px;">
                            @if (SelectedNode != null)
                            {
                                <table class="red-ui-info-table">
                                    <tbody>
                                        <tr>
                                            <td>node</td>
                                            <td>@NodeId</td>
                                        </tr>
                                        <tr>
                                            <td>type</td>
                                            <td>@NodeType</td>
                                        </tr>
                                        <tr>
                                            <td>name</td>
                                            <td>@(NodeName ?? "(none)")</td>
                                        </tr>
                                        @if (!string.IsNullOrEmpty(StatusText))
                                        {
                                            <tr>
                                                <td>status</td>
                                                <td>
                                                    <span class="red-ui-flow-node-status" style="background-color: @StatusColor;"></span>
                                                    <span>@StatusText</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>

                                @* Node description/info *@
                                @if (!string.IsNullOrEmpty(NodeDescription))
                                {
                                    <div class="red-ui-info-section">
                                        <p>@NodeDescription</p>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="red-ui-help-info-none">
                                    Select a node or flow to view info
                                </div>
                            }
                        </div>
                    </div>
                </ContentTemplate>
            </SplitterPane>
        </SplitterPanes>
    </SfSplitter>

    @* Tips box at bottom *@
    @if (_showTips)
    {
        <div class="red-ui-help-tips">
            <div class="red-ui-help-tip">
                <i class="fa fa-lightbulb-o"></i> @_displayTip
            </div>
            <div class="red-ui-help-tips-buttons">
                <a href="javascript:void(0)" class="red-ui-footer-button" @onclick="NextTip" title="Next tip">
                    <i class="fa fa-refresh"></i>
                </a>
                <a href="javascript:void(0)" class="red-ui-footer-button" @onclick="HideTips" title="Hide tips">
                    <i class="fa fa-times"></i>
                </a>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public object? SelectedNode { get; set; }
    [Parameter] public string NodeId { get; set; } = "";
    [Parameter] public string NodeType { get; set; } = "";
    [Parameter] public string? NodeName { get; set; }
    [Parameter] public string NodeColor { get; set; } = "#ddd";
    [Parameter] public string? NodeDescription { get; set; }
    [Parameter] public string? StatusText { get; set; }
    [Parameter] public string StatusColor { get; set; } = "transparent";
    [Parameter] public string? SelectedNodeId { get; set; }
    [Parameter] public string? SelectedFlowId { get; set; }
    [Parameter] public string CurrentTip { get; set; } = "Click and drag the left edge of this panel to change its width";
    [Parameter] public List<FlowInfo> Flows { get; set; } = new();
    [Parameter] public List<NodeInfo> GlobalConfigNodes { get; set; } = new();
    [Parameter] public EventCallback<string> OnNodeSelected { get; set; }
    [Parameter] public EventCallback<string> OnFlowSelected { get; set; }
    [Parameter] public EventCallback OnRevealClick { get; set; }
    [Parameter] public EventCallback OnCopyLinkClick { get; set; }
    [Parameter] public EventCallback OnHelpClick { get; set; }
    [Parameter] public Func<string, List<NodeInfo>>? GetFlowNodesFunc { get; set; }

    // TreeView reference and state
    private SfTreeView<TreeItem>? _treeView;
    private HashSet<string> _expandedNodeIds = new() { "flows" };
    private string? _selectedTreeNodeId;

    // Tips
    private string[] _tips = new[]
    {
        "Click and drag the left edge of this panel to change its width",
        "Use Ctrl+Z to undo changes",
        "Press Delete to remove selected nodes",
        "Ctrl+click to select multiple nodes"
    };
    private int _currentTipIndex = 0;
    private string _displayTip = "";
    private bool _showTips = true;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(_displayTip))
        {
            _displayTip = CurrentTip;
        }
        // Update selected tree node when external selection changes
        if (!string.IsNullOrEmpty(SelectedNodeId))
        {
            _selectedTreeNodeId = SelectedNodeId;
        }
        else if (!string.IsNullOrEmpty(SelectedFlowId))
        {
            _selectedTreeNodeId = SelectedFlowId;
        }
    }

    private string GetNodeSelectionClass(TreeItem context)
    {
        if (_selectedTreeNodeId == context.Id)
        {
            return "selected";
        }
        return "";
    }

    private List<TreeItem> GetTreeData()
    {
        var items = new List<TreeItem>();

        // Flows section
        items.Add(new TreeItem
        {
            Id = "flows",
            Text = "Flows",
            ParentId = null,
            HasChildren = true,
            Expanded = _expandedNodeIds.Contains("flows"),
            IconCss = "fa fa-sitemap"
        });

        foreach (var flow in Flows)
        {
            items.Add(new TreeItem
            {
                Id = flow.Id,
                Text = flow.Label,
                ParentId = "flows",
                HasChildren = true,
                Expanded = _expandedNodeIds.Contains(flow.Id),
                IconCss = "fa fa-sitemap",
                IsFlow = true
            });

            // Add flow nodes only if flow is expanded
            if (_expandedNodeIds.Contains(flow.Id))
            {
                var flowNodes = GetFlowNodesFunc?.Invoke(flow.Id) ?? new List<NodeInfo>();
                foreach (var node in flowNodes)
                {
                    items.Add(new TreeItem
                    {
                        Id = node.Id,
                        Text = node.Name ?? node.Type,
                        ParentId = flow.Id,
                        HasChildren = false,
                        Color = node.Color,
                        IconCss = "fa fa-square",
                        IsNode = true
                    });
                }
            }
        }

        // Subflows section
        items.Add(new TreeItem
        {
            Id = "subflows",
            Text = "Subflows",
            ParentId = null,
            HasChildren = false,
            Expanded = _expandedNodeIds.Contains("subflows"),
            IconCss = "fa fa-share-alt"
        });

        // Global Configuration section
        items.Add(new TreeItem
        {
            Id = "global-config",
            Text = "Global Configuration",
            ParentId = null,
            HasChildren = GlobalConfigNodes.Any(),
            Expanded = _expandedNodeIds.Contains("global-config"),
            IconCss = "fa fa-cog"
        });

        foreach (var node in GlobalConfigNodes)
        {
            items.Add(new TreeItem
            {
                Id = node.Id,
                Text = node.Name ?? node.Type,
                ParentId = "global-config",
                HasChildren = false,
                Color = node.Color,
                IsNode = true
            });
        }

        return items;
    }

    private async Task OnNodeClicked(NodeClickEventArgs args)
    {
        var nodeId = args.NodeData?.Id;
        if (nodeId == null) return;

        // Update local selection state
        _selectedTreeNodeId = nodeId;

        var treeItem = GetTreeData().FirstOrDefault(t => t.Id == nodeId);
        if (treeItem != null)
        {
            if (treeItem.IsFlow)
            {
                // Toggle expansion for flows
                if (_expandedNodeIds.Contains(nodeId))
                {
                    _expandedNodeIds.Remove(nodeId);
                }
                else
                {
                    _expandedNodeIds.Add(nodeId);
                }
                await OnFlowSelected.InvokeAsync(treeItem.Id);
            }
            else if (treeItem.IsNode)
            {
                await OnNodeSelected.InvokeAsync(treeItem.Id);
            }
            else if (treeItem.HasChildren)
            {
                // Toggle expansion for category nodes (Flows, Subflows, Global Config)
                if (_expandedNodeIds.Contains(nodeId))
                {
                    _expandedNodeIds.Remove(nodeId);
                }
                else
                {
                    _expandedNodeIds.Add(nodeId);
                }
            }
        }
        StateHasChanged();
    }

    private void OnNodeExpanding(NodeExpandEventArgs args)
    {
        // Prevent default expansion behavior - we handle it manually in OnNodeClicked
        if (args.NodeData?.Id != null)
        {
            var nodeId = args.NodeData.Id;
            if (!_expandedNodeIds.Contains(nodeId))
            {
                _expandedNodeIds.Add(nodeId);
            }
        }
    }

    private void NextTip()
    {
        _currentTipIndex = (_currentTipIndex + 1) % _tips.Length;
        _displayTip = _tips[_currentTipIndex];
    }

    private void HideTips()
    {
        _showTips = false;
    }

    public class TreeItem
    {
        public string Id { get; set; } = "";
        public string Text { get; set; } = "";
        public string? ParentId { get; set; }
        public bool HasChildren { get; set; } = false;
        public bool Expanded { get; set; } = false;
        public string? IconCss { get; set; }
        public string? Color { get; set; }
        public bool IsFlow { get; set; } = false;
        public bool IsNode { get; set; } = false;
    }

    public class FlowInfo
    {
        public string Id { get; set; } = "";
        public string Label { get; set; } = "";
        public bool Disabled { get; set; } = false;
    }

    public class NodeInfo
    {
        public string Id { get; set; } = "";
        public string Type { get; set; } = "";
        public string? Name { get; set; }
        public string Color { get; set; } = "#ddd";
    }
}
