@using Syncfusion.Blazor.Layouts

@*
    RedUiSidebarInfo - Blazor implementation of Node-RED's tab-info.js
    Uses Syncfusion SfSplitter for resizable panels
*@

<div class="red-ui-sidebar-info" style="height: 100%; display: flex; flex-direction: column;">
    <SfSplitter Height="100%" Width="100%" Orientation="Syncfusion.Blazor.Layouts.Orientation.Vertical" CssClass="red-ui-info-splitter">
        <SplitterPanes>
            @* Outliner panel (tree view of flows) *@
            <SplitterPane Size="40%" Min="100px" Collapsible="true">
                <ContentTemplate>
                    <div class="red-ui-info-outliner" style="height: 100%; overflow: auto;">
                        <ul class="red-ui-treeview-list" style="list-style: none; margin: 0; padding: 0;">
                            @foreach (var item in GetTreeData().Where(t => t.ParentId == null))
                            {
                                @RenderTreeNode(item)
                            }
                        </ul>
                    </div>
                </ContentTemplate>
            </SplitterPane>

            @* Properties panel *@
            <SplitterPane Min="100px">
                <ContentTemplate>
                    <div class="red-ui-info-properties" style="height: 100%; overflow: hidden; display: flex; flex-direction: column;">
                        @* Header with node type icon and name *@
                        <div class="red-ui-palette-header red-ui-info-header" style="display: flex; align-items: center; padding: 5px 10px; background: #f3f3f3; border-bottom: 1px solid #ddd;">
                            @if (SelectedNode != null)
                            {
                                <span class="red-ui-info-header-icon" style="width: 20px; height: 16px; background-color: @NodeColor; border: 1px solid #999; border-radius: 2px; margin-right: 8px;"></span>
                                <span class="red-ui-info-header-label" style="flex: 1; font-weight: 500;">@NodeType</span>

                                @* Action buttons *@
                                <button type="button" class="red-ui-button red-ui-button-small red-ui-info-header-button"
                                        title="Show node help" @onclick="OnHelpClick" style="margin-left: 4px; padding: 2px 6px; border: 1px solid #ccc; background: #fff; border-radius: 3px; cursor: pointer;">
                                    <i class="fa fa-book"></i>
                                </button>
                                <button type="button" class="red-ui-button red-ui-button-small red-ui-info-header-button"
                                        title="Copy node path" @onclick="OnCopyLinkClick" style="margin-left: 4px; padding: 2px 6px; border: 1px solid #ccc; background: #fff; border-radius: 3px; cursor: pointer;">
                                    <i class="fa fa-link"></i>
                                </button>
                                <button type="button" class="red-ui-button red-ui-button-small red-ui-info-header-button"
                                        title="Reveal in workspace" @onclick="OnRevealClick" style="margin-left: 4px; padding: 2px 6px; border: 1px solid #ccc; background: #fff; border-radius: 3px; cursor: pointer;">
                                    <i class="fa fa-search"></i>
                                </button>
                            }
                            else
                            {
                                <span class="red-ui-info-header-none" style="color: #888;">No selection</span>
                            }
                        </div>

                        @* Properties content *@
                        <div class="red-ui-info-properties-content" style="flex: 1; overflow-y: auto; padding: 10px;">
                            @if (SelectedNode != null)
                            {
                                <table class="red-ui-info-table" style="width: 100%; border-collapse: collapse; font-size: 13px;">
                                    <tbody>
                                        <tr>
                                            <td style="padding: 4px 8px; background: #f9f9f9; width: 80px; color: #666;">node</td>
                                            <td style="padding: 4px 8px;">@NodeId</td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 4px 8px; background: #f9f9f9; color: #666;">type</td>
                                            <td style="padding: 4px 8px;">@NodeType</td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 4px 8px; background: #f9f9f9; color: #666;">name</td>
                                            <td style="padding: 4px 8px;">@(NodeName ?? "(none)")</td>
                                        </tr>
                                        @if (!string.IsNullOrEmpty(StatusText))
                                        {
                                            <tr>
                                                <td style="padding: 4px 8px; background: #f9f9f9; color: #666;">status</td>
                                                <td style="padding: 4px 8px;">
                                                    <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background-color: @StatusColor; margin-right: 4px;"></span>
                                                    <span>@StatusText</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>

                                @* Node description/info *@
                                @if (!string.IsNullOrEmpty(NodeDescription))
                                {
                                    <div style="margin-top: 10px; padding: 8px; background: #f9f9f9; border-radius: 3px;">
                                        <p style="margin: 0;">@NodeDescription</p>
                                    </div>
                                }
                            }
                            else
                            {
                                <div style="color: #888; text-align: center; padding: 20px;">
                                    Select a node or flow to view info
                                </div>
                            }
                        </div>
                    </div>
                </ContentTemplate>
            </SplitterPane>
        </SplitterPanes>
    </SfSplitter>

    @* Tips box at bottom *@
    @if (_showTips)
    {
        <div class="red-ui-help-tips" style="padding: 8px 10px; background: #fffce8; border-top: 1px solid #ddd; display: flex; align-items: center; font-size: 12px;">
            <div style="flex: 1;">
                <i class="fa fa-lightbulb-o" style="color: #c90; margin-right: 6px;"></i> @_displayTip
            </div>
            <div style="display: flex; gap: 4px;">
                <a href="javascript:void(0)" @onclick="NextTip" title="Next tip" style="color: #666; text-decoration: none; padding: 2px 6px;">
                    <i class="fa fa-refresh"></i>
                </a>
                <a href="javascript:void(0)" @onclick="HideTips" title="Hide tips" style="color: #666; text-decoration: none; padding: 2px 6px;">
                    <i class="fa fa-times"></i>
                </a>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public object? SelectedNode { get; set; }
    [Parameter] public string NodeId { get; set; } = "";
    [Parameter] public string NodeType { get; set; } = "";
    [Parameter] public string? NodeName { get; set; }
    [Parameter] public string NodeColor { get; set; } = "#ddd";
    [Parameter] public string? NodeDescription { get; set; }
    [Parameter] public string? StatusText { get; set; }
    [Parameter] public string StatusColor { get; set; } = "transparent";
    [Parameter] public string? SelectedNodeId { get; set; }
    [Parameter] public string? SelectedFlowId { get; set; }
    [Parameter] public string CurrentTip { get; set; } = "Use Ctrl+Z to undo changes";
    [Parameter] public List<FlowInfo> Flows { get; set; } = new();
    [Parameter] public List<NodeInfo> GlobalConfigNodes { get; set; } = new();
    [Parameter] public EventCallback<string> OnNodeSelected { get; set; }
    [Parameter] public EventCallback<string> OnFlowSelected { get; set; }
    [Parameter] public EventCallback OnRevealClick { get; set; }
    [Parameter] public EventCallback OnCopyLinkClick { get; set; }
    [Parameter] public EventCallback OnHelpClick { get; set; }
    [Parameter] public Func<string, List<NodeInfo>>? GetFlowNodesFunc { get; set; }

    // Tree state
    private HashSet<string> _expandedNodeIds = new() { "flows" };
    private string? _selectedTreeNodeId;

    // Tips
    private string[] _tips = new[]
    {
        "Use Ctrl+Z to undo changes",
        "Press Delete to remove selected nodes",
        "Ctrl+click to select multiple nodes",
        "Double-click a node to edit its properties"
    };
    private int _currentTipIndex = 0;
    private string _displayTip = "";
    private bool _showTips = true;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(_displayTip))
        {
            _displayTip = CurrentTip;
        }
        // Update selected tree node when external selection changes
        if (!string.IsNullOrEmpty(SelectedNodeId))
        {
            _selectedTreeNodeId = SelectedNodeId;
        }
        else if (!string.IsNullOrEmpty(SelectedFlowId))
        {
            _selectedTreeNodeId = SelectedFlowId;
        }
    }

    private RenderFragment RenderTreeNode(TreeItem item) => __builder =>
    {
        var isExpanded = _expandedNodeIds.Contains(item.Id);
        var isSelected = _selectedTreeNodeId == item.Id;
        var children = GetTreeData().Where(t => t.ParentId == item.Id).ToList();
        var hasChildren = children.Any() || item.HasChildren;

        <li style="list-style: none;">
            <div class="red-ui-treeview-item @(isSelected ? "selected" : "")" 
                 @onclick="() => OnTreeItemClick(item)"
                 style="display: flex; align-items: center; padding: 4px 8px; cursor: pointer; @(isSelected ? "background-color: #ffebc7;" : "")">
                @* Expand/collapse icon *@
                @if (hasChildren)
                {
                    <i class="fa @(isExpanded ? "fa-caret-down" : "fa-caret-right")" 
                       style="width: 12px; margin-right: 4px; color: #666; font-size: 11px;"></i>
                }
                else
                {
                    <span style="width: 12px; margin-right: 4px;"></span>
                }
                
                @* Node icon - only for actual nodes, not categories *@
                @if (item.IsNode && !string.IsNullOrEmpty(item.Color))
                {
                    <span style="width: 20px; height: 14px; background-color: @item.Color; border: 1px solid #999; border-radius: 2px; margin-right: 6px;"></span>
                }
                else if (!string.IsNullOrEmpty(item.IconCss))
                {
                    <i class="@item.IconCss" style="width: 14px; margin-right: 6px; color: #666; font-size: 12px;"></i>
                }
                
                @* Label *@
                <span style="font-size: 13px;">@item.Text</span>
            </div>
            
            @* Children *@
            @if (hasChildren && isExpanded)
            {
                <ul style="list-style: none; margin: 0; padding-left: 16px;">
                    @foreach (var child in children)
                    {
                        @RenderTreeNode(child)
                    }
                </ul>
            }
        </li>
    };

    private async Task OnTreeItemClick(TreeItem item)
    {
        // Update selection
        _selectedTreeNodeId = item.Id;

        if (item.IsFlow)
        {
            // Toggle expansion for flows
            if (_expandedNodeIds.Contains(item.Id))
            {
                _expandedNodeIds.Remove(item.Id);
            }
            else
            {
                _expandedNodeIds.Add(item.Id);
            }
            await OnFlowSelected.InvokeAsync(item.Id);
        }
        else if (item.IsNode)
        {
            await OnNodeSelected.InvokeAsync(item.Id);
        }
        else if (item.HasChildren)
        {
            // Toggle expansion for category nodes (Flows, Subflows, Global Config)
            if (_expandedNodeIds.Contains(item.Id))
            {
                _expandedNodeIds.Remove(item.Id);
            }
            else
            {
                _expandedNodeIds.Add(item.Id);
            }
        }
    }

    private List<TreeItem> GetTreeData()
    {
        var items = new List<TreeItem>();

        // Flows section
        items.Add(new TreeItem
        {
            Id = "flows",
            Text = "Flows",
            ParentId = null,
            HasChildren = Flows.Any(),
            IconCss = "fa fa-sitemap"
        });

        foreach (var flow in Flows)
        {
            var flowNodes = GetFlowNodesFunc?.Invoke(flow.Id) ?? new List<NodeInfo>();
            items.Add(new TreeItem
            {
                Id = flow.Id,
                Text = flow.Label,
                ParentId = "flows",
                HasChildren = flowNodes.Any(),
                IconCss = "fa fa-sitemap",
                IsFlow = true
            });

            // Add flow nodes
            foreach (var node in flowNodes)
            {
                items.Add(new TreeItem
                {
                    Id = node.Id,
                    Text = node.Name ?? node.Type,
                    ParentId = flow.Id,
                    HasChildren = false,
                    Color = node.Color,
                    IsNode = true
                });
            }
        }

        // Subflows section
        items.Add(new TreeItem
        {
            Id = "subflows",
            Text = "Subflows",
            ParentId = null,
            HasChildren = false,
            IconCss = "fa fa-share-alt"
        });

        // Global Configuration section
        items.Add(new TreeItem
        {
            Id = "global-config",
            Text = "Global Configuration",
            ParentId = null,
            HasChildren = GlobalConfigNodes.Any(),
            IconCss = "fa fa-cog"
        });

        foreach (var node in GlobalConfigNodes)
        {
            items.Add(new TreeItem
            {
                Id = node.Id,
                Text = node.Name ?? node.Type,
                ParentId = "global-config",
                HasChildren = false,
                Color = node.Color,
                IsNode = true
            });
        }

        return items;
    }

    private void NextTip()
    {
        _currentTipIndex = (_currentTipIndex + 1) % _tips.Length;
        _displayTip = _tips[_currentTipIndex];
    }

    private void HideTips()
    {
        _showTips = false;
    }

    public class TreeItem
    {
        public string Id { get; set; } = "";
        public string Text { get; set; } = "";
        public string? ParentId { get; set; }
        public bool HasChildren { get; set; } = false;
        public string? IconCss { get; set; }
        public string? Color { get; set; }
        public bool IsFlow { get; set; } = false;
        public bool IsNode { get; set; } = false;
    }

    public class FlowInfo
    {
        public string Id { get; set; } = "";
        public string Label { get; set; } = "";
        public bool Disabled { get; set; } = false;
    }

    public class NodeInfo
    {
        public string Id { get; set; } = "";
        public string Type { get; set; } = "";
        public string? Name { get; set; }
        public string Color { get; set; } = "#ddd";
    }
}
