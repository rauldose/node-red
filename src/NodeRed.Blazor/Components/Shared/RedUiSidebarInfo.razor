@*
    RedUiSidebarInfo - Blazor implementation of Node-RED's tab-info.js
    Matches the exact structure from packages/node_modules/@node-red/editor-client/src/js/ui/tab-info.js
    
    Structure:
    - Split panel with outliner (top) and properties (bottom)
    - Resizable panels with 60/40 ratio
    - Treeview for flows/nodes
    - Properties table for selected node
    - Tips box at bottom
*@

<div class="red-ui-sidebar-info" style="height: 100%; display: flex; flex-direction: column;">
    @* Split panel container *@
    <div class="red-ui-sidebar-info-stack" style="flex: 1; display: flex; flex-direction: column; overflow: hidden;">
        @* Outliner panel (tree view of flows) - 60% height *@
        <div class="red-ui-info-outliner" style="flex: 0 0 @(_outlinerHeightPercent)%; overflow: auto; border-bottom: 2px solid #ddd;">
            <div class="red-ui-treeList" style="height: 100%;">
                @* Flows section *@
                <div class="red-ui-treeList-container">
                    <div class="red-ui-treeList-row" @onclick="() => ToggleFlowsExpanded()">
                        <span class="red-ui-treeList-icon">
                            <i class="fa @(_flowsExpanded ? "fa-caret-down" : "fa-caret-right")"></i>
                        </span>
                        <span class="red-ui-treeList-label">Flows</span>
                    </div>
                    @if (_flowsExpanded)
                    {
                        <div class="red-ui-treeList-children">
                            @foreach (var flow in Flows)
                            {
                                <div class="red-ui-treeList-container">
                                    <div class="red-ui-treeList-row @(SelectedFlowId == flow.Id ? "selected" : "")"
                                         @onclick="() => SelectFlow(flow.Id)"
                                         @onclick:stopPropagation="true">
                                        <span class="red-ui-treeList-icon" @onclick="() => ToggleFlowExpanded(flow.Id)" @onclick:stopPropagation="true">
                                            <i class="fa @(IsFlowExpanded(flow.Id) ? "fa-caret-down" : "fa-caret-right")"></i>
                                        </span>
                                        <span class="red-ui-info-outline-item red-ui-info-outline-item-flow">
                                            <span class="red-ui-info-outline-item-label">@flow.Label</span>
                                        </span>
                                    </div>
                                    @if (IsFlowExpanded(flow.Id))
                                    {
                                        <div class="red-ui-treeList-children">
                                            @foreach (var node in GetFlowNodes(flow.Id))
                                            {
                                                <div class="red-ui-treeList-row @(SelectedNodeId == node.Id ? "selected" : "")"
                                                     @onclick="() => SelectNode(node.Id)">
                                                    <span class="red-ui-node-list-item red-ui-info-outline-item">
                                                        <span class="red-ui-palette-icon-container" style="background-color: @node.Color; width: 18px; height: 15px; border-radius: 3px; margin-right: 6px; display: inline-block; border: 1px solid #999;"></span>
                                                        <span class="red-ui-info-outline-item-label">@(node.Name ?? node.Type)</span>
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
                
                @* Subflows section *@
                <div class="red-ui-treeList-container">
                    <div class="red-ui-treeList-row" @onclick="() => _subflowsExpanded = !_subflowsExpanded">
                        <span class="red-ui-treeList-icon">
                            <i class="fa @(_subflowsExpanded ? "fa-caret-down" : "fa-caret-right")"></i>
                        </span>
                        <span class="red-ui-treeList-label">Subflows</span>
                    </div>
                    @if (_subflowsExpanded)
                    {
                        <div class="red-ui-treeList-children">
                            <div class="red-ui-info-outline-item-empty">empty</div>
                        </div>
                    }
                </div>
                
                @* Global Config section *@
                <div class="red-ui-treeList-container">
                    <div class="red-ui-treeList-row" @onclick="() => _globalConfigExpanded = !_globalConfigExpanded">
                        <span class="red-ui-treeList-icon">
                            <i class="fa @(_globalConfigExpanded ? "fa-caret-down" : "fa-caret-right")"></i>
                        </span>
                        <span class="red-ui-treeList-label">Global Configuration</span>
                    </div>
                    @if (_globalConfigExpanded)
                    {
                        <div class="red-ui-treeList-children">
                            @if (GlobalConfigNodes.Any())
                            {
                                @foreach (var node in GlobalConfigNodes)
                                {
                                    <div class="red-ui-treeList-row @(SelectedNodeId == node.Id ? "selected" : "")"
                                         @onclick="() => SelectNode(node.Id)">
                                        <span class="red-ui-node-list-item red-ui-info-outline-item">
                                            <span class="red-ui-palette-icon-container" style="background-color: @node.Color; width: 18px; height: 15px; border-radius: 3px; margin-right: 6px; display: inline-block; border: 1px solid #999;"></span>
                                            <span class="red-ui-info-outline-item-label">@(node.Name ?? node.Type)</span>
                                        </span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="red-ui-info-outline-item-empty">empty</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
        
        @* Resize handle *@
        <div class="red-ui-panels-separator" style="height: 6px; background: #f3f3f3; cursor: row-resize; flex-shrink: 0;"
             @onmousedown="StartResize"></div>
        
        @* Properties panel - remaining space *@
        <div class="red-ui-info-properties" style="flex: 1; overflow: hidden; display: flex; flex-direction: column;">
            @* Header with node type icon and name *@
            <div class="red-ui-palette-header red-ui-info-header">
                @if (SelectedNode != null)
                {
                    <span class="red-ui-info-header-icon" style="background-color: @NodeColor;"></span>
                    <span class="red-ui-info-header-label">@NodeType</span>
                    
                    @* Action buttons *@
                    <button type="button" class="red-ui-button red-ui-button-small red-ui-info-header-button" 
                            title="Show node help" @onclick="OnHelpClick">
                        <i class="fa fa-book"></i>
                    </button>
                    <button type="button" class="red-ui-button red-ui-button-small red-ui-info-header-button" 
                            title="Copy node path" @onclick="OnCopyLinkClick">
                        <i class="fa fa-link"></i>
                    </button>
                    <button type="button" class="red-ui-button red-ui-button-small red-ui-info-header-button" 
                            title="Reveal in workspace" @onclick="OnRevealClick">
                        <i class="fa fa-search"></i>
                    </button>
                }
                else
                {
                    <span class="red-ui-info-header-none">No selection</span>
                }
            </div>
            
            @* Properties content *@
            <div class="red-ui-info-properties-content">
                @if (SelectedNode != null)
                {
                    <table class="red-ui-info-table">
                        <tbody>
                            <tr>
                                <td>node</td>
                                <td>@NodeId</td>
                            </tr>
                            <tr>
                                <td>type</td>
                                <td>@NodeType</td>
                            </tr>
                            <tr>
                                <td>name</td>
                                <td>@(NodeName ?? "(none)")</td>
                            </tr>
                            @if (!string.IsNullOrEmpty(StatusText))
                            {
                                <tr>
                                    <td>status</td>
                                    <td>
                                        <span class="red-ui-flow-node-status" style="background-color: @StatusColor;"></span>
                                        <span>@StatusText</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    
                    @* Node description/info *@
                    @if (!string.IsNullOrEmpty(NodeDescription))
                    {
                        <div class="red-ui-info-section">
                            <p>@NodeDescription</p>
                        </div>
                    }
                }
                else
                {
                    <div class="red-ui-help-info-none">
                        Select a node or flow to view info
                    </div>
                }
            </div>
        </div>
    </div>
    
    @* Tips box at bottom *@
    @if (_showTips)
    {
        <div class="red-ui-help-tips">
            <div class="red-ui-help-tip">
                <i class="fa fa-lightbulb-o"></i> @_displayTip
            </div>
            <div class="red-ui-help-tips-buttons">
                <a href="javascript:void(0)" class="red-ui-footer-button" @onclick="NextTip" title="Next tip">
                    <i class="fa fa-refresh"></i>
                </a>
                <a href="javascript:void(0)" class="red-ui-footer-button" @onclick="HideTips" title="Hide tips">
                    <i class="fa fa-times"></i>
                </a>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public object? SelectedNode { get; set; }
    [Parameter] public string NodeId { get; set; } = "";
    [Parameter] public string NodeType { get; set; } = "";
    [Parameter] public string? NodeName { get; set; }
    [Parameter] public string NodeColor { get; set; } = "#ddd";
    [Parameter] public string? NodeDescription { get; set; }
    [Parameter] public string? StatusText { get; set; }
    [Parameter] public string StatusColor { get; set; } = "transparent";
    [Parameter] public string? SelectedNodeId { get; set; }
    [Parameter] public string? SelectedFlowId { get; set; }
    [Parameter] public string CurrentTip { get; set; } = "Click and drag the left edge of this panel to change its width";
    [Parameter] public List<FlowInfo> Flows { get; set; } = new();
    [Parameter] public List<NodeInfo> GlobalConfigNodes { get; set; } = new();
    [Parameter] public EventCallback<string> OnNodeSelected { get; set; }
    [Parameter] public EventCallback<string> OnFlowSelected { get; set; }
    [Parameter] public EventCallback OnRevealClick { get; set; }
    [Parameter] public EventCallback OnCopyLinkClick { get; set; }
    [Parameter] public EventCallback OnHelpClick { get; set; }
    [Parameter] public Func<string, List<NodeInfo>>? GetFlowNodesFunc { get; set; }

    // Panel state
    private int _outlinerHeightPercent = 60;
    private bool _flowsExpanded = true;
    private bool _subflowsExpanded = false;
    private bool _globalConfigExpanded = false;
    private HashSet<string> _expandedFlows = new();

    // Tips - matches original Node-RED tips
    private string[] _tips = new[]
    {
        "Click and drag the left edge of this panel to change its width",
        "Use Ctrl+Z to undo changes",
        "Press Delete to remove selected nodes",
        "Ctrl+click to select multiple nodes"
    };
    private int _currentTipIndex = 0;

    protected override void OnInitialized()
    {
        // Expand first flow by default
        if (Flows.Any())
        {
            _expandedFlows.Add(Flows.First().Id);
        }
    }

    private void ToggleFlowsExpanded() => _flowsExpanded = !_flowsExpanded;

    private void ToggleFlowExpanded(string flowId)
    {
        if (_expandedFlows.Contains(flowId))
            _expandedFlows.Remove(flowId);
        else
            _expandedFlows.Add(flowId);
    }

    private bool IsFlowExpanded(string flowId) => _expandedFlows.Contains(flowId);

    private List<NodeInfo> GetFlowNodes(string flowId)
    {
        if (GetFlowNodesFunc != null)
            return GetFlowNodesFunc(flowId);
        return new List<NodeInfo>();
    }

    private async Task SelectFlow(string flowId)
    {
        // Expand the flow when selecting it
        if (!_expandedFlows.Contains(flowId))
        {
            _expandedFlows.Add(flowId);
        }
        await OnFlowSelected.InvokeAsync(flowId);
    }

    private async Task SelectNode(string nodeId)
    {
        await OnNodeSelected.InvokeAsync(nodeId);
    }

    private void StartResize()
    {
        // TODO: Implement drag resize
    }

    private void NextTip()
    {
        _currentTipIndex = (_currentTipIndex + 1) % _tips.Length;
        _displayTip = _tips[_currentTipIndex];
    }

    private void HideTips()
    {
        _showTips = false;
    }

    // Local state for tips
    private string _displayTip = "";
    private bool _showTips = true;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(_displayTip))
        {
            _displayTip = CurrentTip;
        }
    }

    public class FlowInfo
    {
        public string Id { get; set; } = "";
        public string Label { get; set; } = "";
        public bool Disabled { get; set; } = false;
    }

    public class NodeInfo
    {
        public string Id { get; set; } = "";
        public string Type { get; set; } = "";
        public string? Name { get; set; }
        public string Color { get; set; } = "#ddd";
    }
}
