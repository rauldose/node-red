@*
    RedUiSidebarInfo - Blazor implementation of Node-RED's tab-info.js
    Matches the exact structure from packages/node_modules/@node-red/editor-client/src/js/ui/tab-info.js
*@

<div class="red-ui-sidebar-info">
    <div class="red-ui-sidebar-info-stack">
        @* Outliner panel (tree view of flows) *@
        <div class="red-ui-info-outliner" style="overflow: hidden; height: 70%;">
            @if (OutlinerContent != null)
            {
                @OutlinerContent
            }
            else
            {
                <div class="red-ui-treeList" style="padding: 5px;">
                    <div class="red-ui-treeList-label" style="padding: 5px; cursor: pointer;">
                        <i class="fa fa-angle-right" style="margin-right: 5px;"></i>
                        <span>@CurrentFlowName</span>
                    </div>
                </div>
            }
        </div>
        
        @* Properties panel *@
        <div class="red-ui-info-properties" style="overflow: hidden; height: 100%; display: flex; flex-direction: column;">
            @* Header with node type icon and name *@
            <div class="red-ui-palette-header red-ui-info-header" style="flex: 0 0 auto; position: relative; padding: 10px;">
                @if (SelectedNode != null)
                {
                    <span class="red-ui-info-header-icon" style="display: inline-block; width: 20px; height: 17px; border-radius: 3px; border: 1px solid #999; margin-right: 8px; background-color: @NodeColor;"></span>
                    <span class="red-ui-info-header-label" style="font-weight: 500;">@NodeType</span>
                    
                    @* Action buttons *@
                    <button type="button" class="red-ui-button red-ui-button-small" style="position: absolute; top: 12px; right: 8px;" title="Reveal in workspace" @onclick="OnRevealClick">
                        <i class="fa fa-search"></i>
                    </button>
                    <button type="button" class="red-ui-button red-ui-button-small" style="position: absolute; top: 12px; right: 32px;" title="Copy node path" @onclick="OnCopyLinkClick">
                        <i class="fa fa-link"></i>
                    </button>
                    <button type="button" class="red-ui-button red-ui-button-small" style="position: absolute; top: 12px; right: 56px;" title="Show node help" @onclick="OnHelpClick">
                        <i class="fa fa-book"></i>
                    </button>
                }
                else
                {
                    <span style="color: #888;">No selection</span>
                }
            </div>
            
            @* Properties content *@
            <div class="red-ui-info-properties-content" style="flex: 1; overflow-y: auto; padding: 10px;">
                @if (SelectedNode != null)
                {
                    <table class="red-ui-info-table">
                        <tbody>
                            <tr>
                                <td>node</td>
                                <td class="red-ui-info-table-value">@NodeId</td>
                            </tr>
                            <tr>
                                <td>type</td>
                                <td class="red-ui-info-table-value">@NodeType</td>
                            </tr>
                            <tr>
                                <td>name</td>
                                <td class="red-ui-info-table-value">@(NodeName ?? "(none)")</td>
                            </tr>
                            @if (!string.IsNullOrEmpty(StatusText))
                            {
                                <tr>
                                    <td>status</td>
                                    <td class="red-ui-info-table-value">
                                        <span class="red-ui-flow-node-status" style="background-color: @StatusColor; @StatusStyle"></span>
                                        <span style="margin-left: 5px;">@StatusText</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    
                    @* Node description/info *@
                    @if (!string.IsNullOrEmpty(NodeDescription))
                    {
                        <div class="red-ui-info-section" style="margin-top: 15px;">
                            <p>@NodeDescription</p>
                        </div>
                    }
                }
                else
                {
                    <div class="red-ui-help-info-none" style="color: #888; text-align: center; padding: 20px;">
                        Select a node or flow to view info
                    </div>
                }
            </div>
        </div>
    </div>
    
    @* Tips box at bottom *@
    <div class="red-ui-sidebar-info-tips" style="padding: 8px; background: #ffffc0; border-top: 1px solid #ddd;">
        <div class="red-ui-sidebar-tip">
            <span><i class="fa fa-lightbulb-o"></i> @CurrentTip</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public object? SelectedNode { get; set; }
    [Parameter] public string NodeId { get; set; } = "";
    [Parameter] public string NodeType { get; set; } = "";
    [Parameter] public string? NodeName { get; set; }
    [Parameter] public string NodeColor { get; set; } = "#ddd";
    [Parameter] public string? NodeDescription { get; set; }
    [Parameter] public string? StatusText { get; set; }
    [Parameter] public string StatusColor { get; set; } = "transparent";
    [Parameter] public string StatusStyle { get; set; } = "";
    [Parameter] public string CurrentFlowName { get; set; } = "Flow 1";
    [Parameter] public string CurrentTip { get; set; } = "Click and drag the left edge of this panel to change its width";
    [Parameter] public RenderFragment? OutlinerContent { get; set; }
    [Parameter] public EventCallback OnRevealClick { get; set; }
    [Parameter] public EventCallback OnCopyLinkClick { get; set; }
    [Parameter] public EventCallback OnHelpClick { get; set; }
}
