@using Syncfusion.Blazor.Layouts
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Inputs

@*
    RedUiSidebarHelp - Blazor implementation using pure Syncfusion components
    Uses SfTreeView for tree list and SfSplitter for resizable panels
*@

<div style="height: 100%; display: flex; flex-direction: column;">
    @* Toolbar *@
    <div style="padding: 8px 12px; border-bottom: 1px solid #e0e0e0; display: flex; align-items: center; gap: 8px; flex-shrink: 0;">
        <SfButton IconCss="fa fa-list-ul" CssClass="@(ShowTOC ? "e-primary" : "")" OnClick="ToggleTOC" Title="@(ShowTOC ? "Hide topics" : "Show topics")"></SfButton>
        <SfTextBox Placeholder="Search help..." @bind-Value="SearchQuery" CssClass="e-small" Width="100%"></SfTextBox>
    </div>

    @* Content area *@
    <div style="flex: 1; overflow: hidden;">
        @if (ShowTOC)
        {
            <SfSplitter Height="100%" Width="100%" Orientation="Orientation.Vertical">
                <SplitterPanes>
                    @* TOC panel (tree) *@
                    <SplitterPane Size="35%" Min="80px" Collapsible="true">
                        <ContentTemplate>
                            <SfTreeView TValue="TreeItem" @ref="_treeView" CssClass="sidebar-help-tree">
                                <TreeViewEvents TValue="TreeItem" NodeClicked="OnNodeClicked"></TreeViewEvents>
                                <TreeViewFieldsSettings TValue="TreeItem" 
                                    DataSource="@GetFilteredTreeData()"
                                    Id="Id" 
                                    Text="Text" 
                                    ParentID="ParentId" 
                                    HasChildren="HasChildren"
                                    Expanded="IsExpanded"
                                    IconCss="IconCss">
                                </TreeViewFieldsSettings>
                            </SfTreeView>
                        </ContentTemplate>
                    </SplitterPane>

                    @* Help content panel *@
                    <SplitterPane Min="100px">
                        <ContentTemplate>
                            <div style="height: 100%; overflow-y: auto; padding: 12px;">
                                @RenderHelpContent()
                            </div>
                        </ContentTemplate>
                    </SplitterPane>
                </SplitterPanes>
            </SfSplitter>
        }
        else
        {
            @* Help content only (no TOC) *@
            <div style="height: 100%; overflow-y: auto; padding: 12px;">
                @RenderHelpContent()
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string? SelectedNodeType { get; set; }
    [Parameter] public string? HelpSummary { get; set; }
    [Parameter] public string? HelpDetails { get; set; }
    [Parameter] public List<HelpProperty>? HelpInputs { get; set; }
    [Parameter] public List<HelpProperty>? HelpOutputs { get; set; }
    [Parameter] public List<HelpReference>? HelpReferences { get; set; }
    [Parameter] public RenderFragment? HelpContent { get; set; }
    [Parameter] public List<NodeCategory> Categories { get; set; } = new();
    [Parameter] public EventCallback<string> OnNodeTypeSelected { get; set; }

    private SfTreeView<TreeItem>? _treeView;
    private bool ShowTOC { get; set; } = true;
    private string SearchQuery { get; set; } = "";

    private void ToggleTOC()
    {
        ShowTOC = !ShowTOC;
    }

    private List<TreeItem> GetFilteredTreeData()
    {
        var items = new List<TreeItem>();
        var filteredCategories = string.IsNullOrEmpty(SearchQuery)
            ? Categories
            : Categories.Select(c => new NodeCategory
            {
                Name = c.Name,
                Expanded = true,
                Nodes = c.Nodes.Where(n =>
                    n.Type.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    n.Label.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
                ).ToList()
            }).Where(c => c.Nodes.Count > 0).ToList();

        foreach (var category in filteredCategories)
        {
            var catId = $"cat-{category.Name}";
            items.Add(new TreeItem
            {
                Id = catId,
                Text = category.Name,
                ParentId = null,
                HasChildren = category.Nodes.Any(),
                IsExpanded = category.Expanded || !string.IsNullOrEmpty(SearchQuery),
                IconCss = "fa fa-folder"
            });

            foreach (var node in category.Nodes)
            {
                items.Add(new TreeItem
                {
                    Id = node.Type,
                    Text = node.Label,
                    ParentId = catId,
                    HasChildren = false,
                    Color = node.Color,
                    IsNode = true
                });
            }
        }

        return items;
    }

    private async Task OnNodeClicked(NodeClickEventArgs args)
    {
        var nodeData = args.NodeData;
        if (nodeData.IsNode)
        {
            await OnNodeTypeSelected.InvokeAsync(nodeData.Id);
        }
    }

    private RenderFragment RenderHelpContent() => __builder =>
    {
        if (HelpContent != null)
        {
            @HelpContent
        }
        else if (!string.IsNullOrEmpty(SelectedNodeType))
        {
            <h3 style="margin-top: 0; border-bottom: 1px solid #e0e0e0; padding-bottom: 10px;">@SelectedNodeType</h3>
            if (!string.IsNullOrEmpty(HelpSummary))
            {
                <p style="margin: 10px 0; color: #333;">@HelpSummary</p>
            }
            if (HelpInputs?.Count > 0)
            {
                <h4 style="margin: 16px 0 8px; color: #666;">Inputs</h4>
                <dl style="margin: 0;">
                    @foreach (var input in HelpInputs)
                    {
                        <dt style="font-weight: 500; margin-top: 8px;">@input.Name <span style="font-weight: normal; color: #888;">@input.Type</span></dt>
                        <dd style="margin: 4px 0 0 16px; color: #555;">@input.Description</dd>
                    }
                </dl>
            }
            if (HelpOutputs?.Count > 0)
            {
                <h4 style="margin: 16px 0 8px; color: #666;">Outputs</h4>
                <dl style="margin: 0;">
                    @foreach (var output in HelpOutputs)
                    {
                        <dt style="font-weight: 500; margin-top: 8px;">@output.Name <span style="font-weight: normal; color: #888;">@output.Type</span></dt>
                        <dd style="margin: 4px 0 0 16px; color: #555;">@output.Description</dd>
                    }
                </dl>
            }
            if (!string.IsNullOrEmpty(HelpDetails))
            {
                <h4 style="margin: 16px 0 8px; color: #666;">Details</h4>
                <p style="margin: 0; white-space: pre-wrap; color: #333;">@HelpDetails</p>
            }
            if (HelpReferences?.Count > 0)
            {
                <h4 style="margin: 16px 0 8px; color: #666;">References</h4>
                <ul style="margin: 0; padding-left: 20px;">
                    @foreach (var reference in HelpReferences)
                    {
                        <li><a href="@reference.Url" target="_blank">@reference.Title</a></li>
                    }
                </ul>
            }
        }
        else
        {
            <span style="color: #888;">Select a node type to view help</span>
        }
    };

    public class TreeItem
    {
        public string Id { get; set; } = "";
        public string Text { get; set; } = "";
        public string? ParentId { get; set; }
        public bool HasChildren { get; set; } = false;
        public bool IsExpanded { get; set; } = false;
        public string? IconCss { get; set; }
        public string? Color { get; set; }
        public bool IsNode { get; set; } = false;
    }

    public class HelpProperty
    {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public string Description { get; set; } = "";
    }

    public class HelpReference
    {
        public string Title { get; set; } = "";
        public string Url { get; set; } = "";
    }

    public class NodeCategory
    {
        public string Name { get; set; } = "";
        public bool Expanded { get; set; } = false;
        public List<NodeInfo> Nodes { get; set; } = new();
    }

    public class NodeInfo
    {
        public string Type { get; set; } = "";
        public string Label { get; set; } = "";
        public string Color { get; set; } = "#ddd";
    }
}
