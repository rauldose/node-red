@*
    RedUiSidebarHelp - Blazor implementation of Node-RED's tab-help.js
    Uses Syncfusion SfSplitter and SfTreeView for proper functionality
*@

<div class="red-ui-sidebar-help" style="height: 100%; display: flex; flex-direction: column;">
    @* Toolbar with toggle button and search *@
    <div class="red-ui-sidebar-header red-ui-info-toolbar" style="padding: 5px 10px; border-bottom: 1px solid #ddd; flex-shrink: 0; display: flex; align-items: center;">
        <span class="button-group">
            <a class="red-ui-button red-ui-button-small @(ShowTOC ? "selected" : "")" href="javascript:void(0)" @onclick="ToggleTOC" title="@(ShowTOC ? "Hide topics" : "Show topics")">
                <i class="fa fa-list-ul"></i>
            </a>
        </span>
        <SfTextBox Placeholder="Search help..." CssClass="red-ui-help-search" @bind-Value="@SearchQuery"
                   Width="150px" ShowClearButton="true" Input="OnSearchInput"></SfTextBox>
    </div>

    @* Splitter with TOC on top and content below *@
    <SfSplitter Orientation="Syncfusion.Blazor.Layouts.Orientation.Vertical" CssClass="red-ui-help-splitter" Height="100%">
        <SplitterPanes>
            @* TOC panel (tree) - visible when ShowTOC is true *@
            @if (ShowTOC)
            {
                <SplitterPane Size="30%" Min="100px" Collapsible="true">
                    <ContentTemplate>
                        <div class="red-ui-sidebar-help-toc" style="height: 100%; overflow: auto; padding: 5px;">
                            <SfTreeView TValue="HelpTreeItem" CssClass="red-ui-help-treeview"
                                        NodeClicked="OnHelpNodeClicked">
                                <TreeViewFieldsSettings TValue="HelpTreeItem"
                                                        DataSource="@GetFilteredTreeData()"
                                                        Id="Id"
                                                        Text="Text"
                                                        ParentID="ParentId"
                                                        HasChildren="HasChildren"
                                                        Expanded="Expanded">
                                </TreeViewFieldsSettings>
                                <TreeViewTemplates TValue="HelpTreeItem">
                                    <NodeTemplate>
                                        <div class="red-ui-help-tree-node @(context.Id == SelectedNodeType ? "selected" : "")">
                                            @if (!string.IsNullOrEmpty(context.Color))
                                            {
                                                <span class="red-ui-palette-icon-container" style="background-color: @context.Color; width: 15px; height: 12px; border-radius: 2px; margin-right: 6px; display: inline-block; border: 1px solid #999;"></span>
                                            }
                                            <span class="red-ui-help-tree-label">@context.Text</span>
                                        </div>
                                    </NodeTemplate>
                                </TreeViewTemplates>
                            </SfTreeView>
                        </div>
                    </ContentTemplate>
                </SplitterPane>
            }

            @* Help content panel *@
            <SplitterPane Size="@(ShowTOC ? "70%" : "100%")" Min="150px">
                <ContentTemplate>
                    <div class="red-ui-sidebar-help-content" style="height: 100%; overflow-y: auto; padding: 10px;">
                        <div class="red-ui-help">
                            @if (HelpContent != null)
                            {
                                @HelpContent
                            }
                            else if (!string.IsNullOrEmpty(SelectedNodeType))
                            {
                                <h3 style="margin-top: 0; border-bottom: 1px solid #ddd; padding-bottom: 8px;">@SelectedNodeType</h3>
                                @if (!string.IsNullOrEmpty(HelpSummary))
                                {
                                    <p>@HelpSummary</p>
                                }
                                @if (HelpInputs?.Count > 0)
                                {
                                    <h4>Inputs</h4>
                                    <dl class="message-properties">
                                        @foreach (var input in HelpInputs)
                                        {
                                            <dt>@input.Name <span class="property-type">@input.Type</span></dt>
                                            <dd>@input.Description</dd>
                                        }
                                    </dl>
                                }
                                @if (HelpOutputs?.Count > 0)
                                {
                                    <h4>Outputs</h4>
                                    <dl class="message-properties">
                                        @foreach (var output in HelpOutputs)
                                        {
                                            <dt>@output.Name <span class="property-type">@output.Type</span></dt>
                                            <dd>@output.Description</dd>
                                        }
                                    </dl>
                                }
                                @if (!string.IsNullOrEmpty(HelpDetails))
                                {
                                    <h4>Details</h4>
                                    <p style="white-space: pre-wrap;">@HelpDetails</p>
                                }
                                @if (HelpReferences?.Count > 0)
                                {
                                    <h4>References</h4>
                                    <ul>
                                        @foreach (var reference in HelpReferences)
                                        {
                                            <li><a href="@reference.Url" target="_blank">@reference.Title</a></li>
                                        }
                                    </ul>
                                }
                            }
                            else
                            {
                                <span class="red-ui-help-info-none">Select a node type to view help</span>
                            }
                        </div>
                    </div>
                </ContentTemplate>
            </SplitterPane>
        </SplitterPanes>
    </SfSplitter>
</div>

@code {
    [Parameter] public string? SelectedNodeType { get; set; }
    [Parameter] public string? HelpSummary { get; set; }
    [Parameter] public string? HelpDetails { get; set; }
    [Parameter] public List<HelpProperty>? HelpInputs { get; set; }
    [Parameter] public List<HelpProperty>? HelpOutputs { get; set; }
    [Parameter] public List<HelpReference>? HelpReferences { get; set; }
    [Parameter] public RenderFragment? HelpContent { get; set; }
    [Parameter] public List<NodeCategory> Categories { get; set; } = new();
    [Parameter] public EventCallback<string> OnNodeTypeSelected { get; set; }

    private bool ShowTOC { get; set; } = true;
    private string SearchQuery { get; set; } = "";

    private void ToggleTOC() => ShowTOC = !ShowTOC;

    private void OnSearchInput(InputEventArgs args)
    {
        SearchQuery = args.Value ?? "";
    }

    private List<HelpTreeItem> GetFilteredTreeData()
    {
        var items = new List<HelpTreeItem>();
        var filteredCategories = string.IsNullOrEmpty(SearchQuery)
            ? Categories
            : Categories.Select(c => new NodeCategory
            {
                Name = c.Name,
                Expanded = true,
                Nodes = c.Nodes.Where(n =>
                    n.Type.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    n.Label.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
                ).ToList()
            }).Where(c => c.Nodes.Count > 0).ToList();

        foreach (var category in filteredCategories)
        {
            var categoryId = $"cat-{category.Name}";
            items.Add(new HelpTreeItem
            {
                Id = categoryId,
                Text = category.Name,
                ParentId = null,
                HasChildren = category.Nodes.Any(),
                Expanded = category.Expanded || !string.IsNullOrEmpty(SearchQuery)
            });

            foreach (var node in category.Nodes)
            {
                items.Add(new HelpTreeItem
                {
                    Id = node.Type,
                    Text = node.Label,
                    ParentId = categoryId,
                    HasChildren = false,
                    Color = node.Color,
                    IsNodeType = true
                });
            }
        }

        return items;
    }

    private async Task OnHelpNodeClicked(NodeClickEventArgs args)
    {
        var nodeId = args.NodeData?.Id;
        if (nodeId == null) return;

        var treeItem = GetFilteredTreeData().FirstOrDefault(t => t.Id == nodeId);
        if (treeItem?.IsNodeType == true)
        {
            await OnNodeTypeSelected.InvokeAsync(treeItem.Id);
        }
    }

    public class HelpTreeItem
    {
        public string Id { get; set; } = "";
        public string Text { get; set; } = "";
        public string? ParentId { get; set; }
        public bool HasChildren { get; set; } = false;
        public bool Expanded { get; set; } = false;
        public string? Color { get; set; }
        public bool IsNodeType { get; set; } = false;
    }

    public class HelpProperty
    {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public string Description { get; set; } = "";
    }

    public class HelpReference
    {
        public string Title { get; set; } = "";
        public string Url { get; set; } = "";
    }

    public class NodeCategory
    {
        public string Name { get; set; } = "";
        public bool Expanded { get; set; } = false;
        public List<NodeInfo> Nodes { get; set; } = new();
    }

    public class NodeInfo
    {
        public string Type { get; set; } = "";
        public string Label { get; set; } = "";
        public string Color { get; set; } = "#ddd";
    }
}
