@*
    RedUiSidebarHelp - Blazor implementation of Node-RED's tab-help.js
    Matches the exact structure from packages/node_modules/@node-red/editor-client/src/js/ui/tab-help.js
    
    Structure (vertical layout like original):
    - Toolbar with toggle button and search
    - TOC panel (tree) on TOP - 30% height when visible
    - Help content panel on BOTTOM - remaining height
*@

<div class="red-ui-sidebar-info" style="height: 100%; display: flex; flex-direction: column;">
    @* Toolbar - matches red-ui-sidebar-header red-ui-info-toolbar *@
    <div class="red-ui-sidebar-header red-ui-info-toolbar" style="padding: 5px 10px; border-bottom: 1px solid #ddd; flex-shrink: 0; display: flex; align-items: center;">
        <span class="button-group">
            <a class="red-ui-button red-ui-button-small @(ShowTOC ? "selected" : "")" href="javascript:void(0)" @onclick="ToggleTOC" title="@(ShowTOC ? "Hide topics" : "Show topics")">
                <i class="fa fa-list-ul"></i>
            </a>
        </span>
        <input type="text" class="red-ui-searchBox" placeholder="Search help..." @bind="SearchQuery" @bind:event="oninput" 
               style="margin-left: 10px; padding: 4px 8px; border: 1px solid #ccc; border-radius: 3px; flex: 1; max-width: 200px;" />
    </div>
    
    @* Stack container - vertical layout with TOC on top and content below *@
    <div class="red-ui-sidebar-help-stack" style="flex: 1; display: flex; flex-direction: column; overflow: hidden;">
        @* Table of Contents panel (TOP) - 30% height like original panels.ratio(0.3) *@
        @if (ShowTOC)
        {
            <div class="red-ui-sidebar-help-toc" style="height: @(_tocHeightPercent)%; border-bottom: 1px solid #ddd; overflow-y: auto; flex-shrink: 0;">
                <div class="red-ui-treeList" style="padding: 5px;">
                    @foreach (var category in GetFilteredCategories())
                    {
                        <div class="red-ui-treeList-container">
                            <div class="red-ui-treeList-row" style="padding: 5px; font-weight: bold; cursor: pointer;" @onclick="() => ToggleCategory(category.Name)">
                                <span class="red-ui-treeList-icon">
                                    <i class="fa @(category.Expanded ? "fa-caret-down" : "fa-caret-right")"></i>
                                </span>
                                <span class="red-ui-treeList-label">@category.Name</span>
                            </div>
                            @if (category.Expanded)
                            {
                                <div class="red-ui-treeList-children" style="padding-left: 18px;">
                                    @foreach (var node in category.Nodes)
                                    {
                                        <div class="red-ui-treeList-row @(SelectedNodeType == node.Type ? "selected" : "")" 
                                             style="padding: 3px 8px; cursor: pointer;"
                                             @onclick="() => SelectNodeType(node.Type)">
                                            <span class="red-ui-palette-icon-container" style="display: inline-block; width: 15px; height: 12px; border-radius: 2px; margin-right: 6px; background-color: @node.Color; border: 1px solid #999;"></span>
                                            <span class="red-ui-info-outline-item-label">@node.Label</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            
            @* Resize handle between TOC and content *@
            <div class="red-ui-panels-separator" style="height: 6px; background: #f3f3f3; cursor: row-resize; flex-shrink: 0;"
                 @onmousedown="StartTocResize"></div>
        }
        
        @* Help content panel (BOTTOM) - remaining height *@
        <div class="red-ui-sidebar-help-content" style="flex: 1; overflow-y: auto; padding: 10px;">
            <div class="red-ui-help">
                @if (HelpContent != null)
                {
                    @HelpContent
                }
                else if (!string.IsNullOrEmpty(SelectedNodeType))
                {
                    <h3 style="margin-top: 0; border-bottom: 1px solid #ddd; padding-bottom: 8px;">@SelectedNodeType</h3>
                    @if (!string.IsNullOrEmpty(HelpSummary))
                    {
                        <p>@HelpSummary</p>
                    }
                    @if (HelpInputs?.Count > 0)
                    {
                        <h4>Inputs</h4>
                        <dl class="message-properties">
                            @foreach (var input in HelpInputs)
                            {
                                <dt>@input.Name <span class="property-type">@input.Type</span></dt>
                                <dd>@input.Description</dd>
                            }
                        </dl>
                    }
                    @if (HelpOutputs?.Count > 0)
                    {
                        <h4>Outputs</h4>
                        <dl class="message-properties">
                            @foreach (var output in HelpOutputs)
                            {
                                <dt>@output.Name <span class="property-type">@output.Type</span></dt>
                                <dd>@output.Description</dd>
                            }
                        </dl>
                    }
                    @if (!string.IsNullOrEmpty(HelpDetails))
                    {
                        <h4>Details</h4>
                        <p style="white-space: pre-wrap;">@HelpDetails</p>
                    }
                    @if (HelpReferences?.Count > 0)
                    {
                        <h4>References</h4>
                        <ul>
                            @foreach (var reference in HelpReferences)
                            {
                                <li><a href="@reference.Url" target="_blank">@reference.Title</a></li>
                            }
                        </ul>
                    }
                }
                else
                {
                    <span class="red-ui-help-info-none" style="color: #888;">Select a node type to view help</span>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? SelectedNodeType { get; set; }
    [Parameter] public string? HelpSummary { get; set; }
    [Parameter] public string? HelpDetails { get; set; }
    [Parameter] public List<HelpProperty>? HelpInputs { get; set; }
    [Parameter] public List<HelpProperty>? HelpOutputs { get; set; }
    [Parameter] public List<HelpReference>? HelpReferences { get; set; }
    [Parameter] public RenderFragment? HelpContent { get; set; }
    [Parameter] public List<NodeCategory> Categories { get; set; } = new();
    [Parameter] public EventCallback<string> OnNodeTypeSelected { get; set; }

    private bool ShowTOC { get; set; } = true;
    private string SearchQuery { get; set; } = "";
    
    // TOC panel height - default 30% like original panels.ratio(0.3)
    private int _tocHeightPercent = 30;

    private void ToggleTOC() => ShowTOC = !ShowTOC;

    private void ToggleCategory(string name)
    {
        var category = Categories.FirstOrDefault(c => c.Name == name);
        if (category != null)
        {
            category.Expanded = !category.Expanded;
        }
    }

    private async Task SelectNodeType(string nodeType)
    {
        await OnNodeTypeSelected.InvokeAsync(nodeType);
    }
    
    private void StartTocResize()
    {
        // TODO: Implement drag resize via JS interop
    }

    private IEnumerable<NodeCategory> GetFilteredCategories()
    {
        if (string.IsNullOrEmpty(SearchQuery))
            return Categories;
        
        return Categories.Select(c => new NodeCategory
        {
            Name = c.Name,
            Expanded = true,
            Nodes = c.Nodes.Where(n => 
                n.Type.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                n.Label.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            ).ToList()
        }).Where(c => c.Nodes.Count > 0);
    }

    public class HelpProperty
    {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public string Description { get; set; } = "";
    }

    public class HelpReference
    {
        public string Title { get; set; } = "";
        public string Url { get; set; } = "";
    }

    public class NodeCategory
    {
        public string Name { get; set; } = "";
        public bool Expanded { get; set; } = false;
        public List<NodeInfo> Nodes { get; set; } = new();
    }

    public class NodeInfo
    {
        public string Type { get; set; } = "";
        public string Label { get; set; } = "";
        public string Color { get; set; } = "#ddd";
    }
}
