@page "/editor"
@page "/"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Diagram
@using Syncfusion.Blazor.Diagram.SymbolPalette
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.SplitButtons
@using Syncfusion.Blazor.Inputs
@using System.Collections.ObjectModel
@inject INodeRegistry NodeRegistry
@inject IFlowRuntime FlowRuntime
@inject IFlowStorage FlowStorage
@inject IJSRuntime JSRuntime

<PageTitle>Node-RED Flow Editor</PageTitle>

<div class="control-section">
    <div style="width: 100%">
        <!-- Main Toolbar -->
        <SfToolbar>
            <ToolbarEvents Clicked="@ToolbarEditorClick"></ToolbarEvents>
            <ToolbarItems>
                <ToolbarItem TooltipText="Deploy" PrefixIcon="e-icons e-play" Text="Deploy"></ToolbarItem>
                <ToolbarItem Type="ItemType.Separator"></ToolbarItem>
                <ToolbarItem TooltipText="Undo" PrefixIcon="e-icons e-undo" Disabled="@IsEnableUndoButton"></ToolbarItem>
                <ToolbarItem TooltipText="Redo" PrefixIcon="e-icons e-redo" Disabled="@IsEnableRedoButton"></ToolbarItem>
                <ToolbarItem Type="ItemType.Separator"></ToolbarItem>
                <ToolbarItem TooltipText="Cut" PrefixIcon="e-icons e-cut" Disabled="@IsEnableCutButton"></ToolbarItem>
                <ToolbarItem TooltipText="Copy" PrefixIcon="e-icons e-copy" Disabled="@IsEnableCopyButton"></ToolbarItem>
                <ToolbarItem TooltipText="Paste" PrefixIcon="e-icons e-paste" Disabled="@IsEnablePasteButton"></ToolbarItem>
                <ToolbarItem Type="ItemType.Separator"></ToolbarItem>
                <ToolbarItem TooltipText="Delete" PrefixIcon="e-icons e-trash" Disabled="@IsDeleteDisable"></ToolbarItem>
                <ToolbarItem Type="ItemType.Separator"></ToolbarItem>
                <ToolbarItem TooltipText="Pan" PrefixIcon="e-icons e-pan"></ToolbarItem>
                <ToolbarItem TooltipText="Select" PrefixIcon="e-icons e-mouse-pointer"></ToolbarItem>
                <ToolbarItem Type="ItemType.Separator"></ToolbarItem>
                <ToolbarItem TooltipText="Draw Connectors">
                    <Template>
                        <SfDropDownButton IconCss="e-icons e-connector">
                            <DropDownButtonEvents ItemSelected="@SelectedItem"></DropDownButtonEvents>
                            <DropDownMenuItems>
                                <DropDownMenuItem IconCss="e-icons e-line" Text="Straight"></DropDownMenuItem>
                                <DropDownMenuItem Text="Orthogonal"></DropDownMenuItem>
                                <DropDownMenuItem Text="Bezier"></DropDownMenuItem>
                            </DropDownMenuItems>
                        </SfDropDownButton>
                    </Template>
                </ToolbarItem>
                <ToolbarItem Type="ItemType.Separator"></ToolbarItem>
                <ToolbarItem>
                    <Template>
                        <SfDropDownButton Content="@ZoomItemDropdownContent">
                            <DropDownButtonEvents ItemSelected="@SelectedZoomItem"></DropDownButtonEvents>
                            <DropDownMenuItems>
                                <DropDownMenuItem Text="Zoom In"></DropDownMenuItem>
                                <DropDownMenuItem Text="Zoom Out"></DropDownMenuItem>
                                <DropDownMenuItem Text="Zoom to Fit"></DropDownMenuItem>
                                <DropDownMenuItem Text="Zoom to 50%"></DropDownMenuItem>
                                <DropDownMenuItem Text="Zoom to 100%"></DropDownMenuItem>
                                <DropDownMenuItem Text="Zoom to 200%"></DropDownMenuItem>
                            </DropDownMenuItems>
                        </SfDropDownButton>
                    </Template>
                </ToolbarItem>
                <ToolbarItem Type="ItemType.Separator"></ToolbarItem>
                <ToolbarItem Text="@RuntimeStateText" PrefixIcon="@RuntimeStateIcon"></ToolbarItem>
            </ToolbarItems>
        </SfToolbar>

        <!-- Main Content Area -->
        <div class="main-content">
            <!-- Node Palette -->
            <div id="palette-space" class="palette-space">
                <SfSymbolPaletteComponent @ref="@PaletteInstance" 
                                          Height="100%" 
                                          ShowSearchTextBox="true" 
                                          SymbolDragPreviewSize="@SymbolPreview" 
                                          Palettes="@DiagramPalettes" 
                                          SymbolHeight="40" 
                                          SymbolWidth="100" 
                                          SymbolMargin="@SymbolMargin">
                </SfSymbolPaletteComponent>
            </div>

            <!-- Diagram Area with Flow Tabs -->
            <div id="diagram-space" class="diagram-space">
                <!-- Flow Tabs -->
                <div class="flow-tabs">
                    @foreach (var flow in Flows)
                    {
                        <div class="flow-tab @(CurrentFlowId == flow.Id ? "active" : "")" 
                             @onclick="() => SwitchFlow(flow.Id)">
                            <span class="flow-tab-name">@flow.Label</span>
                            @if (Flows.Count > 1)
                            {
                                <span class="flow-tab-close" @onclick:stopPropagation="true" @onclick="() => DeleteFlow(flow.Id)">×</span>
                            }
                        </div>
                    }
                    <div class="flow-tab-add" @onclick="AddNewFlow">
                        <span class="e-icons e-plus"></span>
                    </div>
                </div>

                <!-- Diagram Canvas -->
                <div class="content-wrapper" style="border: 1px solid #D7D7D7">
                    <SfDiagramComponent @ref="@DiagramInstance" 
                                        Connectors="@DiagramConnectors" 
                                        Created="OnCreated" 
                                        SelectionChanged="@OnSelectionChanged" 
                                        Height="calc(100vh - 140px)" 
                                        Nodes="@DiagramNodes" 
                                        NodeCreating="OnNodeCreating" 
                                        ConnectorCreating="OnConnectorCreating">
                        <RulerSettings>
                            <HorizontalRuler></HorizontalRuler>
                            <VerticalRuler></VerticalRuler>
                        </RulerSettings>
                        <SnapSettings>
                            <HorizontalGridLines LineColor="#e0e0e0" LineIntervals="@GridLineIntervals">
                            </HorizontalGridLines>
                            <VerticalGridLines LineColor="#e0e0e0" LineIntervals="@GridLineIntervals">
                            </VerticalGridLines>
                        </SnapSettings>
                        <PageSettings MultiplePage="true">
                            <BackgroundStyle Background="#fafafa" />
                        </PageSettings>
                        <ContextMenuSettings Show="true"></ContextMenuSettings>
                    </SfDiagramComponent>
                </div>
            </div>

            <!-- Right Sidebar: Properties & Debug -->
            <div id="sidebar-space" class="sidebar-space">
                <SfTab @bind-SelectedItem="@SelectedSidebarTab">
                    <TabItems>
                        <!-- Properties Tab -->
                        <TabItem>
                            <ChildContent>
                                <TabHeader Text="Properties" />
                            </ChildContent>
                            <ContentTemplate>
                                <div class="sidebar-content properties-panel">
                                    @if (SelectedDiagramNode != null)
                                    {
                                        <div class="property-group">
                                            <label class="property-label">Node Type</label>
                                            <div class="property-value node-type">@GetSelectedNodeType()</div>
                                        </div>
                                        <div class="property-group">
                                            <label class="property-label">ID</label>
                                            <div class="property-value">@SelectedDiagramNode.ID</div>
                                        </div>
                                        <div class="property-group">
                                            <label class="property-label">Name</label>
                                            <SfTextBox @bind-Value="@SelectedNodeName" Placeholder="Enter node name" 
                                                       ValueChange="@OnNodeNameChanged"></SfTextBox>
                                        </div>
                                        <div class="property-group">
                                            <label class="property-label">Position X</label>
                                            <SfNumericTextBox TValue="double" @bind-Value="@PositionX"></SfNumericTextBox>
                                        </div>
                                        <div class="property-group">
                                            <label class="property-label">Position Y</label>
                                            <SfNumericTextBox TValue="double" @bind-Value="@PositionY"></SfNumericTextBox>
                                        </div>
                                        @if (GetSelectedNodeType() == "function")
                                        {
                                            <div class="property-group">
                                                <label class="property-label">Function Code</label>
                                                <SfTextBox @bind-Value="@SelectedNodeFunctionCode" Multiline="true" 
                                                           Placeholder="msg.Payload = msg.Payload * 2; return msg;"
                                                           CssClass="function-editor"></SfTextBox>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-muted">Select a node to see its properties</p>
                                    }
                                </div>
                            </ContentTemplate>
                        </TabItem>
                        <!-- Debug/Output Tab -->
                        <TabItem>
                            <ChildContent>
                                <TabHeader Text="Debug" />
                            </ChildContent>
                            <ContentTemplate>
                                <div class="sidebar-content debug-panel">
                                    <div class="debug-header">
                                        <SfButton CssClass="e-small" Content="Clear" OnClick="@ClearDebugMessages" />
                                        <span class="debug-count">@DebugMessages.Count messages</span>
                                    </div>
                                    <div class="debug-messages">
                                        @foreach (var msg in DebugMessages.TakeLast(100).Reverse())
                                        {
                                            <div class="debug-message">
                                                <span class="debug-time">@msg.Timestamp.ToString("HH:mm:ss.fff")</span>
                                                <span class="debug-node">@msg.NodeName</span>
                                                <pre class="debug-data">@FormatDebugData(msg.Data)</pre>
                                            </div>
                                        }
                                        @if (DebugMessages.Count == 0)
                                        {
                                            <p class="text-muted" style="padding: 15px;">No debug messages yet. Deploy and run the flow to see output.</p>
                                        }
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>
                        <!-- Info Tab -->
                        <TabItem>
                            <ChildContent>
                                <TabHeader Text="Info" />
                            </ChildContent>
                            <ContentTemplate>
                                <div class="sidebar-content info-panel">
                                    <h6>Node-RED for .NET</h6>
                                    <p>Visual flow-based programming tool.</p>
                                    <hr />
                                    <p><strong>Current Flow:</strong> @GetCurrentFlowLabel()</p>
                                    <p><strong>Nodes:</strong> @(DiagramNodes?.Count ?? 0)</p>
                                    <p><strong>Connectors:</strong> @(DiagramConnectors?.Count ?? 0)</p>
                                    <p><strong>Runtime:</strong> @RuntimeStateText</p>
                                </div>
                            </ContentTemplate>
                        </TabItem>
                    </TabItems>
                </SfTab>
            </div>
        </div>
    </div>
</div>

<style>
    .control-section {
        height: 100vh;
        overflow: hidden;
    }

    .main-content {
        display: flex;
        height: calc(100vh - 50px);
    }

    .palette-space {
        width: 200px;
        min-width: 200px;
        background: #f5f5f5;
        border-right: 1px solid #ddd;
        overflow-y: auto;
    }

    .diagram-space {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .flow-tabs {
        display: flex;
        background: #555;
        padding: 0;
        height: 35px;
        align-items: flex-end;
    }

    .flow-tab {
        display: flex;
        align-items: center;
        padding: 8px 12px;
        background: #666;
        color: #ccc;
        cursor: pointer;
        border-right: 1px solid #555;
        font-size: 12px;
        transition: background 0.2s;
    }

    .flow-tab:hover {
        background: #777;
    }

    .flow-tab.active {
        background: #fafafa;
        color: #333;
        border-bottom: 3px solid #8f0000;
    }

    .flow-tab-name {
        margin-right: 8px;
    }

    .flow-tab-close {
        font-size: 16px;
        font-weight: bold;
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    .flow-tab-close:hover {
        opacity: 1;
    }

    .flow-tab-add {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 8px 12px;
        background: transparent;
        color: #aaa;
        cursor: pointer;
        font-size: 14px;
    }

    .flow-tab-add:hover {
        color: white;
    }

    .content-wrapper {
        flex: 1;
        overflow: hidden;
    }

    .sidebar-space {
        width: 300px;
        min-width: 300px;
        background: #fff;
        border-left: 1px solid #ddd;
    }

    .sidebar-content {
        padding: 15px;
        overflow-y: auto;
        height: calc(100vh - 130px);
    }

    .properties-panel .property-group {
        margin-bottom: 15px;
    }

    .properties-panel .property-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        color: #666;
        margin-bottom: 5px;
        text-transform: uppercase;
    }

    .properties-panel .property-value {
        font-size: 13px;
        color: #333;
        padding: 5px 0;
    }

    .properties-panel .node-type {
        font-weight: 600;
        color: #8f0000;
    }

    .function-editor {
        font-family: monospace;
        min-height: 100px;
    }

    .debug-panel {
        padding: 0;
    }

    .debug-header {
        padding: 10px;
        border-bottom: 1px solid #ddd;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .debug-count {
        font-size: 11px;
        color: #888;
    }

    .debug-messages {
        overflow-y: auto;
        height: calc(100vh - 180px);
    }

    .debug-message {
        padding: 8px 10px;
        border-bottom: 1px solid #eee;
        font-size: 12px;
    }

    .debug-time {
        color: #888;
        margin-right: 8px;
    }

    .debug-node {
        font-weight: 500;
        color: #8f0000;
    }

    .debug-data {
        margin: 5px 0 0 0;
        padding: 5px;
        background: #f8f8f8;
        border-radius: 3px;
        font-size: 11px;
        overflow-x: auto;
        white-space: pre-wrap;
        word-break: break-all;
    }

    .info-panel h6 {
        color: #8f0000;
        margin-bottom: 10px;
    }

    .text-muted {
        color: #888;
        font-size: 13px;
    }

    /* Node styling in diagram */
    .e-diagram .e-node {
        border-radius: 5px;
    }
</style>
