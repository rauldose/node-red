@page "/editor"
@page "/"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Diagram
@using Syncfusion.Blazor.Diagram.SymbolPalette
@using System.Collections.ObjectModel
@inject INodeRegistry NodeRegistry
@inject IFlowRuntime FlowRuntime
@inject IFlowStorage FlowStorage
@inject IJSRuntime JSRuntime

<PageTitle>Node-RED Flow Editor</PageTitle>

<div class="control-section">
    <div style="width: 100%">
        <SfToolbar>
            <ToolbarEvents Clicked="@ToolbarClick"></ToolbarEvents>
            <ToolbarItems>
                <ToolbarItem Text="Deploy" PrefixIcon="e-icons e-play" TooltipText="Deploy"></ToolbarItem>
                <ToolbarItem Type="ItemType.Separator"></ToolbarItem>
                <ToolbarItem Text="Import" PrefixIcon="e-icons e-import" TooltipText="Import"></ToolbarItem>
                <ToolbarItem Text="Export" PrefixIcon="e-icons e-export" TooltipText="Export"></ToolbarItem>
                <ToolbarItem Type="ItemType.Separator"></ToolbarItem>
                <ToolbarItem Text="@RuntimeStateText" PrefixIcon="@RuntimeStateIcon"></ToolbarItem>
            </ToolbarItems>
        </SfToolbar>

        <div id="palette-space" class="palette-space">
            <h5 class="palette-header">Nodes</h5>
            <p class="palette-hint">Click a node, then click on canvas to add</p>
            @foreach (var category in NodeCategories)
            {
                <div class="palette-category">
                    <div class="palette-category-header" @onclick="() => ToggleCategory(category.Key)">
                        <span class="e-icons @(ExpandedCategories.Contains(category.Key) ? "e-chevron-down" : "e-chevron-right")"></span>
                        @category.Key
                    </div>
                    @if (ExpandedCategories.Contains(category.Key))
                    {
                        <div class="palette-category-nodes">
                            @foreach (var node in category.Value)
                            {
                                <div class="palette-node @(SelectedPaletteNode?.Type == node.Type ? "selected" : "")" 
                                     style="background-color: @node.Color"
                                     @onclick="() => OnPaletteNodeClick(node)">
                                    <span class="node-icon">@GetNodeIcon(node)</span>
                                    <span class="node-label">@node.DisplayName</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div id="diagram-space" class="diagram-space">
            <div class="content-wrapper" style="border: 1px solid #D7D7D7; position: relative;">
                <SfDiagramComponent @ref="@DiagramInstance" 
                                    @bind-Nodes="@DiagramNodes" 
                                    @bind-Connectors="@DiagramConnectors"
                                    Height="687px"
                                    Created="OnCreated"
                                    SelectionChanged="@OnSelectionChanged"
                                    NodeCreating="OnNodeCreating"
                                    ConnectorCreating="OnConnectorCreating"
                                    Click="@OnDiagramClick">
                    <SnapSettings>
                        <HorizontalGridLines LineColor="#e0e0e0" LineIntervals="@GridLineIntervals" />
                        <VerticalGridLines LineColor="#e0e0e0" LineIntervals="@GridLineIntervals" />
                    </SnapSettings>
                    <PageSettings MultiplePage="true">
                        <BackgroundStyle Background="#fafafa" />
                    </PageSettings>
                </SfDiagramComponent>
                
                @if (SelectedPaletteNode != null)
                {
                    <div class="placement-hint">
                        Click on the canvas to place the <strong>@SelectedPaletteNode.DisplayName</strong> node. 
                        <button class="btn-cancel" @onclick="CancelNodePlacement">Cancel</button>
                    </div>
                }
            </div>
        </div>

        <div id="sidebar-space" class="sidebar-space">
            <SfTab>
                <TabItems>
                    <TabItem>
                        <ChildContent>
                            <TabHeader Text="Info" />
                        </ChildContent>
                        <ContentTemplate>
                            <div class="sidebar-content">
                                @if (SelectedFlowNode != null)
                                {
                                    <h6>@SelectedFlowNode.Type</h6>
                                    <p><strong>ID:</strong> @SelectedFlowNode.Id</p>
                                    <p><strong>Name:</strong> @(string.IsNullOrEmpty(SelectedFlowNode.Name) ? "(none)" : SelectedFlowNode.Name)</p>
                                }
                                else
                                {
                                    <p class="text-muted">Select a node to see its properties</p>
                                }
                            </div>
                        </ContentTemplate>
                    </TabItem>
                    <TabItem>
                        <ChildContent>
                            <TabHeader Text="Debug" />
                        </ChildContent>
                        <ContentTemplate>
                            <div class="sidebar-content debug-panel">
                                <div class="debug-header">
                                    <SfButton CssClass="e-small" Content="Clear" OnClick="@ClearDebugMessages" />
                                </div>
                                <div class="debug-messages">
                                    @foreach (var msg in DebugMessages.TakeLast(50).Reverse())
                                    {
                                        <div class="debug-message">
                                            <span class="debug-time">@msg.Timestamp.ToString("HH:mm:ss.fff")</span>
                                            <span class="debug-node">@msg.NodeName</span>
                                            <pre class="debug-data">@FormatDebugData(msg.Data)</pre>
                                        </div>
                                    }
                                </div>
                            </div>
                        </ContentTemplate>
                    </TabItem>
                </TabItems>
            </SfTab>
        </div>
    </div>
</div>

<style>
    .control-section {
        height: 100vh;
        overflow: hidden;
    }

    .palette-space {
        width: 200px;
        height: calc(100vh - 50px);
        float: left;
        background: #f5f5f5;
        border-right: 1px solid #ddd;
        overflow-y: auto;
    }

    .palette-header {
        padding: 10px;
        margin: 0;
        background: #8f0000;
        color: white;
        font-size: 14px;
    }
    
    .palette-hint {
        padding: 8px 10px;
        margin: 0;
        font-size: 11px;
        color: #666;
        background: #eee;
        border-bottom: 1px solid #ddd;
    }

    .palette-category-header {
        padding: 8px 10px;
        cursor: pointer;
        background: #eee;
        border-bottom: 1px solid #ddd;
        font-size: 12px;
        font-weight: 500;
    }

    .palette-category-header:hover {
        background: #e5e5e5;
    }

    .palette-category-nodes {
        padding: 5px;
    }

    .palette-node {
        display: flex;
        align-items: center;
        padding: 6px 10px;
        margin: 3px 0;
        border-radius: 4px;
        cursor: pointer;
        font-size: 12px;
        color: #333;
        border: 2px solid transparent;
        transition: border-color 0.2s;
    }

    .palette-node:hover {
        filter: brightness(0.95);
    }
    
    .palette-node.selected {
        border-color: #0066cc;
        box-shadow: 0 0 5px rgba(0, 102, 204, 0.5);
    }

    .node-icon {
        margin-right: 6px;
    }

    .diagram-space {
        width: calc(100% - 500px);
        height: calc(100vh - 50px);
        float: left;
    }

    .sidebar-space {
        width: 300px;
        height: calc(100vh - 50px);
        float: left;
        background: #fff;
        border-left: 1px solid #ddd;
    }

    .sidebar-content {
        padding: 15px;
        overflow-y: auto;
        height: calc(100vh - 130px);
    }

    .debug-panel {
        padding: 0;
    }

    .debug-header {
        padding: 10px;
        border-bottom: 1px solid #ddd;
    }

    .debug-messages {
        overflow-y: auto;
        height: calc(100vh - 180px);
    }

    .debug-message {
        padding: 8px 10px;
        border-bottom: 1px solid #eee;
        font-size: 12px;
    }

    .debug-time {
        color: #888;
        margin-right: 8px;
    }

    .debug-node {
        font-weight: 500;
        color: #8f0000;
    }

    .debug-data {
        margin: 5px 0 0 0;
        padding: 5px;
        background: #f8f8f8;
        border-radius: 3px;
        font-size: 11px;
        overflow-x: auto;
    }
    
    .placement-hint {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        background: #333;
        color: white;
        padding: 10px 20px;
        border-radius: 5px;
        font-size: 14px;
        z-index: 100;
    }
    
    .placement-hint .btn-cancel {
        margin-left: 10px;
        background: #666;
        color: white;
        border: none;
        padding: 3px 10px;
        border-radius: 3px;
        cursor: pointer;
    }
</style>
